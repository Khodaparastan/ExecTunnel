# ExecTunnel Manager — example config file
# Copy to .env (or any name) and fill in your real WSS URLs.
# Run with:  python -m exectunnel.cli manager --env-file .env
#        or: exectunnel manager --env-file .env

# ── Global defaults (apply to all tunnels unless overridden per-tunnel) ───────

# Skip TLS verification for all tunnels (set to false in production)
WSS_INSECURE=true

# Log level for all tunnel subprocesses
LOG_LEVEL=info

# ── Manager behaviour ─────────────────────────────────────────────────────────

# Seconds to wait before first restart attempt after a tunnel exits
RESTART_DELAY=5

# Maximum restart back-off ceiling (seconds)
MAX_RESTART_DELAY=60

# Multiplier applied to RESTART_DELAY after each consecutive failure
BACKOFF_MULTIPLIER=1.5

# How often to TCP-probe the SOCKS port (seconds)
HEALTH_CHECK_INTERVAL=15

# TCP connect timeout for the health probe (seconds)
HEALTH_CHECK_TIMEOUT=3

# How many consecutive health failures trigger a restart
MAX_HEALTH_FAILURES=3

# Grace period after startup before the first health check (seconds)
# Give the tunnel time to bootstrap the agent before probing
STARTUP_GRACE_PERIOD=20

# ── Tunnel definitions ────────────────────────────────────────────────────────
# Each tunnel is identified by a numeric (or string) suffix.
# WSS_URL_<N> is the only required key per tunnel.
# SOCKS_PORT_<N> defaults to 1081, 1082, … if omitted.

# --- Tunnel 1 ---
WSS_URL_1=wss://stream.example.com/exec/39309/?token=YOUR_TOKEN&cols=108&pod=pod-name-1
SOCKS_PORT_1=1081
LABEL_1=pod-1
# WSS_INSECURE_1=true   # per-tunnel TLS override
# LOG_LEVEL_1=debug     # per-tunnel log level override

# --- Tunnel 2 ---
WSS_URL_2=wss://stream.example.com/exec/39309/?token=YOUR_TOKEN&cols=108&pod=pod-name-2
SOCKS_PORT_2=1082
LABEL_2=pod-2

# --- Tunnel 3 ---
WSS_URL_3=wss://stream.example.com/exec/39309/?token=YOUR_TOKEN&cols=108&pod=pod-name-3
SOCKS_PORT_3=1083
LABEL_3=pod-3

# --- Tunnel 4 (different namespace) ---
# WSS_URL_4=wss://stream.example.com/exec/40794/?token=YOUR_TOKEN&cols=108&pod=wmw-deploy-0
# SOCKS_PORT_4=1084
# LABEL_4=wmw-pod
